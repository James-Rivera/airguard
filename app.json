{
  "expo": {
    "name": "AirGuard",
    "slug": "airguard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "airguard",
    "splash": {
      "backgroundColor": "#0266F4",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.airguard.mobile"
    },
    "android": {
      "package": "com.airguard.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0266F4"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
